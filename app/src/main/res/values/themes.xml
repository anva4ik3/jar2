<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.JARVISAssistant" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/jarvis_blue</item>
        <item name="colorPrimaryVariant">@color/jarvis_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/jarvis_cyan</item>
        <item name="colorSecondaryVariant">@color/jarvis_teal</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/background_primary</item>
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background_primary</item>
        <item name="colorSurface">@color/background_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Light theme variant -->
    <style name="Theme.JARVISAssistant.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/jarvis_blue</item>
        <item name="colorPrimaryVariant">@color/jarvis_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/jarvis_cyan</item>
        <item name="colorSecondaryVariant">@color/jarvis_teal</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/gray_light</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/gray_dark</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.JARVISAssistant.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/jarvis_blue</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.JARVISAssistant.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/white</item>
        <item name="strokeColor">@color/jarvis_cyan</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Card styles -->
    <style name="Widget.JARVISAssistant.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/background_secondary</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
    </style>

    <!-- Text styles -->
    <style name="TextAppearance.JARVISAssistant.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.JARVISAssistant.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.JARVISAssistant.Body1" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.JARVISAssistant.Body2" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Dialog styles -->
    <style name="Theme.JARVISAssistant.Dialog" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="colorPrimary">@color/jarvis_blue</item>
        <item name="colorSurface">@color/background_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <!-- Bottom sheet styles -->
    <style name="Theme.JARVISAssistant.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="colorPrimary">@color/jarvis_blue</item>
        <item name="colorSurface">@color/background_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>
</resources> 